{
  "name": "pokecraft-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor Android wrapper for the PokeCraft web client (client-poke.io)",
  "scripts": {
    "build:web": "bash scripts/build-web.sh",
    "sync": "cap sync android",
    "prepare:android": "npm run build:web && npm run sync",
    "open:android": "cap open android",
    "apk:debug": "cd android && ./gradlew assembleDebug",
    "apk:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
